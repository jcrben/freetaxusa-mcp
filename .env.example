# FreeTaxUSA MCP Configuration
# No secrets in this file -- credentials are provided per-call via tool inputs

# Browser profile directory (default: ~/.freetaxusa-mcp/browser-profile/)
# FREETAXUSA_USER_DATA_DIR=~/.freetaxusa-mcp/browser-profile/

# Headless mode (default: true, set to false for debugging)
# FREETAXUSA_HEADLESS=false

# Tax year (default: 2025)
# FREETAXUSA_TAX_YEAR=2025

# Enable integration tests (requires valid credentials)
# FREETAXUSA_INTEGRATION=true
